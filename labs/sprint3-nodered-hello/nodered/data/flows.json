        "name": "Normalize + Store",
        "func": "const safeNum = (value) => {\n  const n = Number(value);\n  return Number.isFinite(n) ? n : null;\n};\n\nlet payload = msg.payload;\nif (typeof payload === \"string\") {\n  try {\n    payload = JSON.parse(payload);\n  } catch (err) {\n    return null;\n  }\n}\n\nif (!payload || typeof payload !== \"object\") {\n  return null;\n}\n\nconst topic = String(msg.topic || \"\");\nconst parts = topic.split(\"/\");\nif (parts.length !== 4 || parts[0] !== \"home\") {\n  return null;\n}\n\nconst environment = parts[1];\nconst device = parts[2];\nconst messageType = parts[3];\nconst key = `${environment}/${device}`;\n\nconst latest = global.get(\"iotLatest\") || {};\nconst history = global.get(\"iotHistory\") || {};\n\nif (!latest[key]) {\n  latest[key] = {};\n}\n\nconst normalized = {\n  ...payload,\n  ts: payload.ts || new Date().toISOString(),\n  environment,\n  device_id: payload.device_id || device,\n  broker: msg.brokerSource || \"unknown\"\n};\n\nlatest[key].environment = environment;\nlatest[key].device = device;\nlatest[key].broker = msg.brokerSource || \"unknown\";\nlatest[key].updated_at = normalized.ts;\nlatest[key][messageType] = normalized;\n\nif (messageType === \"telemetry\") {\n  if (!history[key]) {\n    history[key] = [];\n  }\n\n  history[key].push({\n    ts: normalized.ts,\n    temp_c: safeNum(normalized.temp_c),\n    humidity_pct: safeNum(normalized.humidity_pct)\n  });\n\n  if (history[key].length > 60) {\n    history[key].shift();\n  }\n}\n\nglobal.set(\"iotLatest\", latest);\nglobal.set(\"iotHistory\", history);\n\nmsg.payload = normalized;\nmsg.meta = {\n  key,\n  environment,\n  device,\n  messageType,\n  broker: msg.brokerSource || \"unknown\"\n};\n\nreturn msg;",
