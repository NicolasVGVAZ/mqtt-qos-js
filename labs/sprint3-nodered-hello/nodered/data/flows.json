    {
        "id": "c3cec173cac1a3d1",
        "type": "function",
        "z": "flow_iot_orq_01",
        "name": "Render Dashboard HTML",
        "func": "const latest = global.get(\"iotLatest\") || {};\nconst history = global.get(\"iotHistory\") || {};\n\nconst esc = (value) => String(value ?? \"\").replace(/[&<>\"']/g, (ch) => ({\n  '&': '&amp;',\n  '<': '&lt;',\n  '>': '&gt;',\n  '\\\"': '&quot;',\n  \"'\": '&#39;'\n}[ch]));\n\nconst deviceKeys = Object.keys(latest).sort();\n\nconst sparkline = (rows) => {\n  if (!Array.isArray(rows) || rows.length === 0) {\n    return '<div class=\"empty\">Sem histórico ainda</div>';\n  }\n\n  const points = rows\n    .map((item) => Number(item.temp_c))\n    .filter((n) => Number.isFinite(n));\n\n  if (points.length === 0) {\n    return '<div class=\"empty\">Sem pontos de temperatura</div>';\n  }\n\n  const min = Math.min(...points);\n  const max = Math.max(...points);\n  const span = (max - min) || 1;\n  const width = 220;\n  const height = 70;\n\n  const chartPoints = points.map((temp, i) => {\n    const x = Math.round((i / Math.max(points.length - 1, 1)) * width);\n    const y = Math.round(height - ((temp - min) / span) * height);\n    return `${x},${y}`;\n  }).join(' ');\n\n  return `<svg viewBox=\"0 0 ${width} ${height}\" class=\"spark\" aria-label=\"histórico de temperatura\"><polyline fill=\"none\" stroke=\"#0b7285\" stroke-width=\"2.5\" points=\"${chartPoints}\"/></svg>`;\n};\n\nlet cards = '';\nfor (const key of deviceKeys) {\n  const item = latest[key] || {};\n  const telemetry = item.telemetry || {};\n  const status = item.status || {};\n  const rows = history[key] || [];\n\n  cards += `\n    <section class=\"card\">\n      <h3>${esc(key)}</h3>\n      <p><strong>Broker:</strong> ${esc(item.broker || \"n/a\")}</p>\n      <p><strong>Temperatura:</strong> ${esc(telemetry.temp_c ?? \"-\")} °C</p>\n      <p><strong>Umidade:</strong> ${esc(telemetry.humidity_pct ?? telemetry[\"humidity-pct\"] ?? \"-\")} %</p>\n      <p><strong>LED:</strong> ${status.led_on === true ? \"ON\" : status.led_on === false ? \"OFF\" : \"-\"}</p>\n      <p><strong>Atualizado:</strong> ${esc(item.updated_at || \"-\")}</p>\n      ${sparkline(rows)}\n    </section>\n  `;\n}\n\nif (!cards) {\n  cards = '<p class=\"empty\">Nenhum dispositivo recebido ainda.</p>';\n}\n\nmsg.headers = { \"Content-Type\": \"text/html; charset=utf-8\" };\nmsg.payload = `<!doctype html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<meta http-equiv=\"refresh\" content=\"2\" />\n<title>Node-RED IoT MQTT</title>\n<style>\n:root{--bg:#f2efe8;--panel:#fffdf8;--ink:#172026;--accent:#0b7285;--line:#d8d2c8;}\n*{box-sizing:border-box}body{margin:0;font-family:Segoe UI,Arial,sans-serif;color:var(--ink);background:radial-gradient(circle at 30% 20%,#fff7dd 0%,var(--bg) 45%,#e9f2f3 100%)}\nmain{max-width:1100px;margin:0 auto;padding:20px}h1{margin:0 0 8px 0}p{margin:6px 0}\n.panel{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:16px;margin-bottom:14px;box-shadow:0 8px 24px rgba(0,0,0,.05)}\n.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px}\n.card{background:#fff;border:1px solid var(--line);border-radius:10px;padding:12px}\n.spark{width:100%;height:70px;background:#fbfcff;border:1px solid #d7e8eb;border-radius:6px}\nform{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;align-items:end}\nlabel{display:block;font-size:12px;margin-bottom:4px}input,select,button{width:100%;padding:9px;border-radius:8px;border:1px solid var(--line);font-size:14px}\nbutton{background:var(--accent);color:#fff;font-weight:600;border:0;cursor:pointer}\nbutton:hover{filter:brightness(.94)}.empty{color:#6b7280}\ncode{background:#ece7df;padding:2px 4px;border-radius:4px}\n</style>\n</head>\n<body>\n<main>\n  <div class=\"panel\">\n    <h1>Orquestração MQTT com Node-RED</h1>\n    <p>Entrada: <code>home/&lt;ambiente&gt;/&lt;dispositivo&gt;/(telemetry|status)</code></p>\n    <p>Comando: <code>home/&lt;ambiente&gt;/&lt;dispositivo&gt;/cmd</code></p>\n  </div>\n\n  <div class=\"panel\">\n    <h2>Controle de dispositivo</h2>\n    <form method=\"post\" action=\"/iot-control\">\n      <div>\n        <label>Broker</label>\n        <select name=\"broker\">\n          <option value=\"local\">Mosquitto local</option>\n          <option value=\"hivemq\">HiveMQ</option>\n          <option value=\"both\">Ambos</option>\n        </select>\n      </div>\n      <div>\n        <label>Ambiente</label>\n        <input name=\"environment\" value=\"living-room\" required />\n      </div>\n      <div>\n        <label>Dispositivo</label>\n        <input name=\"device\" value=\"sensor-001\" required />\n      </div>\n      <div>\n        <label>Comando</label>\n        <select name=\"command\">\n          <option value=\"on\">ON</option>\n          <option value=\"off\">OFF</option>\n        </select>\n      </div>\n      <div>\n        <label>QoS</label>\n        <select name=\"qos\">\n          <option value=\"0\">0</option>\n          <option value=\"1\" selected>1</option>\n        </select>\n      </div>\n      <div>\n        <label>Retain</label>\n        <select name=\"retain\">\n          <option value=\"false\">false</option>\n          <option value=\"true\" selected>true</option>\n        </select>\n      </div>\n      <div>\n        <button type=\"submit\">Enviar comando</button>\n      </div>\n    </form>\n  </div>\n\n  <div class=\"panel\">\n    <h2>Dispositivos recebidos</h2>\n    <div class=\"grid\">${cards}</div>\n  </div>\n</main>\n</body>\n</html>`;\nreturn msg;",
