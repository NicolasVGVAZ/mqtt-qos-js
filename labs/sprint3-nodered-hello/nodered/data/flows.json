    {
        "id": "7e4db912b7765487",
        "type": "function",
        "z": "flow_iot_orq_01",
        "name": "Build + Route Command",
        "func": "let form = msg.payload;\n\nif (typeof form === \"string\") {\n  const params = new URLSearchParams(form);\n  form = {};\n  for (const [k, v] of params.entries()) {\n    form[k] = v;\n  }\n}\n\nform = form || {};\n\nconst environment = String(form.environment || \"living-room\").trim();\nconst device = String(form.device || \"sensor-001\").trim();\nconst broker = String(form.broker || \"local\").trim().toLowerCase();\nconst command = String(form.command || \"off\").trim().toLowerCase();\nconst qos = Number(form.qos) === 0 ? 0 : 1;\nconst retain = String(form.retain || \"true\") === \"true\";\n\nconst topic = `home/${environment}/${device}/cmd`;\nconst payloadObj = {\n  source: \"nodered\",\n  command,\n  ts: new Date().toISOString()\n};\n\nnode.warn(`[iot-control] clique: broker=${broker} topic=${topic} command=${command} qos=${qos} retain=${retain}`);\n\nconst baseMsg = {\n  topic,\n  payload: JSON.stringify(payloadObj),\n  qos,\n  retain\n};\n\nlet outLocal = null;\nlet outHive = null;\nif (broker === \"local\" || broker === \"both\") {\n  outLocal = { ...baseMsg };\n}\nif (broker === \"hivemq\" || broker === \"both\") {\n  outHive = { ...baseMsg };\n}\n\nconst html = `<!doctype html><html lang=\"pt-BR\"><head><meta charset=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><title>Comando enviado</title></head><body style=\"font-family:Segoe UI,Arial,sans-serif;margin:24px\"><h2>Comando publicado</h2><p><strong>Broker:</strong> ${broker}</p><p><strong>Topico:</strong> ${topic}</p><p><strong>Payload:</strong> ${JSON.stringify(payloadObj)}</p><p><strong>QoS:</strong> ${qos} | <strong>Retain:</strong> ${retain}</p><p><a href=\"/iot-ui\">Voltar ao painel</a></p></body></html>`;\nconst outHttp = { ...msg, headers: { \"Content-Type\": \"text/html; charset=utf-8\" }, payload: html };\n\nreturn [outLocal, outHive, outHttp];",
