    "id": "route_temp",
    "type": "function",
    "z": "tab_iot",
    "name": "Route by topic",
    "func": "var t = msg.topic || '';\nif (t === 'projeto/iot/sala/temperatura') { return [msg, null]; }\nif (t === 'projeto/iot/cozinha/temperatura') { return [null, msg]; }\nreturn null;",
